{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@helpers/*": ["src/helpers/*"],
      "@fixtures/*": ["src/fixtures/*"]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src/**/*", "config/**/*"],
  "exclude": ["node_modules", "dist", "test-results", "playwright-report"]
}
